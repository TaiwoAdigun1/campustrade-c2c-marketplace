digraph G { rankdir=LR; node [shape=record, fontname="Arial"]; Role [label="{Role|role_id PK|role_name}"]; User [label="{User|user_id PK|role_id FK|full_name|email|password|phone}"]; Category [label="{Category|category_id PK|category_name}"]; Product [label="{Product|product_id PK|seller_id FK|category_id FK|name|price|status}"]; Cart [label="{Cart|cart_id PK|customer_id FK}"]; CartItem [label="{CartItem|cart_item_id PK|cart_id FK|product_id FK|quantity}"]; Order [label="{Order|order_id PK|customer_id FK|status|total_amount}"]; OrderItem [label="{OrderItem|order_item_id PK|order_id FK|product_id FK|quantity|price}"]; Payment [label="{Payment|payment_id PK|order_id FK|method|status}"]; Role -> User [label="1 to many"]; User -> Product [label="seller lists many"]; Category -> Product [label="1 to many"]; User -> Cart [label="1 to 1"]; Cart -> CartItem [label="1 to many"]; Product -> CartItem [label="1 to many"]; User -> Order [label="1 to many"]; Order -> OrderItem [label="1 to many"]; Product -> OrderItem [label="1 to many"]; Order -> Payment [label="1 to 1"]; }
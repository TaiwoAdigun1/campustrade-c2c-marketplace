digraph G { rankdir=LR; node [shape=box, style="rounded,filled", fillcolor="#eef5ff", fontname="Arial"]; system [label="CampusTrade C2C Marketplace System", fillcolor="#cfe2ff"]; customer [label="Customer"]; seller [label="Seller"]; admin [label="Admin"]; payment [label="Payment Service"]; email [label="Email Notification Service"]; customer -> system [label="register, login, orders"]; system -> customer [label="products, order confirmation"]; seller -> system [label="product details, prices"]; system -> seller [label="sales and order updates"]; admin -> system [label="user, role, product updates"]; system -> admin [label="reports and lists"]; system -> payment [label="payment request"]; payment -> system [label="payment confirmation"]; system -> email [label="notification request"]; email -> system [label="delivery status"]; }
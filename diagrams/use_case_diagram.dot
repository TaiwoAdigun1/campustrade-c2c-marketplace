digraph G { rankdir=LR; node [fontname="Arial"]; customer [shape=box, label="Customer"]; seller [shape=box, label="Seller"]; admin [shape=box, label="Admin"]; subgraph cluster_system { label="CampusTrade System"; style=rounded; register [shape=ellipse, label="Register"]; login [shape=ellipse, label="Login"]; browse [shape=ellipse, label="Browse Products"]; details [shape=ellipse, label="View Product Details"]; cart [shape=ellipse, label="Add to Cart"]; order [shape=ellipse, label="Place Order"]; history [shape=ellipse, label="View Order History"]; add [shape=ellipse, label="Add Product"]; update [shape=ellipse, label="Update Product"]; delete [shape=ellipse, label="Delete Product"]; sales [shape=ellipse, label="View Sales"]; users [shape=ellipse, label="Manage Users"]; roles [shape=ellipse, label="Manage Roles"]; products [shape=ellipse, label="Manage Products"]; categories [shape=ellipse, label="Manage Categories"]; orders [shape=ellipse, label="Manage Orders"]; reports [shape=ellipse, label="View Reports"]; } customer -> register; customer -> login; customer -> browse; customer -> details; customer -> cart; customer -> order; customer -> history; seller -> login; seller -> add; seller -> update; seller -> delete; seller -> sales; admin -> login; admin -> users; admin -> roles; admin -> products; admin -> categories; admin -> orders; admin -> reports; }